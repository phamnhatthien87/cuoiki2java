<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.SignUpController">
    <!-- Nền trang trí phía sau (tùy chọn) -->
    <VBox alignment="CENTER">
        <VBox alignment="CENTER" maxWidth="420.0" spacing="30.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 50;">
            <effect>
                <DropShadow blurType="GAUSSIAN" height="30.0" radius="14.5" width="30.0">
                    <color>
                        <Color opacity="0.08" />
                    </color>
                </DropShadow>
            </effect>

            <!-- Tiêu đề -->
            <VBox alignment="CENTER" spacing="8.0">
                <Label text="TẠO TÀI KHOẢN" textFill="#0F172A">
                    <font><Font name="System Bold" size="28.0" /></font>
                </Label>
                <Label text="Vui lòng nhập thông tin để gia nhập thư viện" textFill="#64748B">
                    <font><Font size="14.0" /></font>
                </Label>
            </VBox>

            <!-- Form Nhập Liệu -->
            <VBox alignment="CENTER_LEFT" spacing="18.0">
                <VBox spacing="8.0">
                    <Label text="Tên đăng nhập" textFill="#475569">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <TextField fx:id="txtNewUser" prefHeight="45.0" promptText="Ví dụ: abcd@2020"
                               style="-fx-background-color: #F1F5F9; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 0 15;" />
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Mật khẩu" textFill="#475569">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <PasswordField fx:id="txtNewPass" prefHeight="45.0" promptText="••••••••"
                                   style="-fx-background-color: #F1F5F9; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 0 15;" />
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Xác nhận mật khẩu" textFill="#475569">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <PasswordField fx:id="txtConfirmPass" prefHeight="45.0" promptText="••••••••"
                                   style="-fx-background-color: #F1F5F9; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 0 15;" />
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Email" textFill="#475569">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <TextField fx:id="txtEmail" prefHeight="45.0" promptText="example@email.com"
                               style="-fx-background-color: #F1F5F9; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 0 15;" />
                </VBox>
            </VBox>

            <!-- Nút Thao Tác -->
            <VBox alignment="CENTER" spacing="20.0">
                <Button maxWidth="Infinity" onAction="#handleSignUp" prefHeight="50.0" text="HOÀN TẤT ĐĂNG KÝ"
                        style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-size: 14;">
                    <effect>
                        <DropShadow height="10.0" radius="4.5" width="10.0">
                            <color><Color red="0.06" green="0.72" blue="0.50" opacity="0.3" /></color>
                        </DropShadow>
                    </effect>
                </Button>

                <HBox alignment="CENTER" spacing="5.0">
                    <Label text="Đã có tài khoản?" textFill="#64748B" />
                    <Hyperlink onAction="#backToLogin" style="-fx-text-fill: #059669; -fx-font-weight: bold; -fx-underline: false;" text="Đăng nhập ngay" />
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</StackPane>