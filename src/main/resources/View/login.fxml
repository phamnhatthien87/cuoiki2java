<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="350.0" prefHeight="250.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.LoginController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <Label text="HỆ THỐNG THƯ VIỆN">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>
    <TextField fx:id="txtUser" promptText="Tên đăng nhập" />
    <PasswordField fx:id="txtPass" promptText="Mật khẩu" />
    <Button text="Đăng nhập" onAction="#handleLogin" prefWidth="100.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
    <Hyperlink text="Chưa có tài khoản? Đăng ký ngay" onAction="#openSignUp" />

</VBox>