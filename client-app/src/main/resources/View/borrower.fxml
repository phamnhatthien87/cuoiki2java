<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.BorrowerController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #e67e22; -fx-padding: 20;">
            <children>
                <Label text="DANH MỤC SÁCH THƯ VIỆN" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Chào mừng bạn quay trở lại!" textFill="WHITE">
                    <font>
                        <Font name="System Italic" size="14.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #f5f6fa;">
            <children>

                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                    <children>
                        <Label text="Tìm kiếm sách:">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtSearch" onAction="#handleSearch" prefHeight="40.0" prefWidth="400.0" promptText="Nhập tên sách hoặc thể loại cần tìm..." style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #dcdde1; -fx-padding: 0 15;" />
                        <Button mnemonicParsing="false" onAction="#handleSearch" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="TÌM KIẾM" />
                    </children>
                </HBox>

                <TableView fx:id="tableBooks" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dcdde1;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="70.0" text="Mã sách" />
                        <TableColumn fx:id="colTitle" prefWidth="280.0" text="Tên tác phẩm" />
                        <TableColumn fx:id="colAuthor" prefWidth="180.0" text="Tác giả" />
                        <TableColumn fx:id="colCategory" prefWidth="140.0" text="Thể loại" />
                        <TableColumn fx:id="colPublisher" prefWidth="160.0" text="Nhà xuất bản" />
                        <TableColumn fx:id="colAvailable" prefWidth="100.0" text="Số lượng" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="20.0" style="-fx-padding: 10 0 0 0;">
                    <children>
                        <Label text="* Ghi chú: Vui lòng chọn một cuốn sách trong danh sách trước khi nhấn mượn." textFill="#7f8c8d">
                            <font>
                                <Font name="System Italic" size="13.0" />
                            </font>
                        </Label>
                        <Button mnemonicParsing="false" onAction="#borrowBook" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15; -fx-background-radius: 30; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 5, 0, 0, 2);" text="XÁC NHẬN MƯỢN SÁCH" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
